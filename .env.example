OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Per-agent models (optional, falls back to OPENROUTER_MODEL)
MODEL_OUTLINE=google/gemini-2.0-flash-001
MODEL_PLANNING=google/gemini-2.0-pro-exp-02-05:free
MODEL_WRITING=google/gemini-2.0-flash-001
MODEL_REALISM=anthropic/claude-3.5-sonnet
MODEL_POLISH=google/gemini-2.0-flash-001
MODEL_ANALYSIS=google/gemini-2.0-flash-001

# Optional: SITE_URL and SITE_NAME for OpenRouter rankings
SITE_URL=http://localhost:3000
SITE_NAME=NovelGenerator
